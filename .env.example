# Копировать в .env и заполнить значениями на VPS

# PostgreSQL
POSTGRES_USER=tmgo_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=tmgo

# Backend
BETTER_AUTH_SECRET=generate_random_32_chars
BETTER_AUTH_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com
CHAT_ATTACHMENT_SECRET=generate_random_32_chars
RESEND_API_KEY=re_xxxxxxxxxxxx

# Frontend (build-time)
NUXT_PUBLIC_API_BASE=https://api.yourdomain.com
NUXT_PUBLIC_WS_URL=wss://api.yourdomain.com

# Ports на хосте (nginx проксирует на эти порты)
BACKEND_PORT=8020
FRONTEND_PORT=3020
