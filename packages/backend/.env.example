DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tmgo"
# Local: default is redis://localhost:6379 when NODE_ENV is not production.
# Railway: add Redis → in the API service Variables use Reference → Redis → REDIS_URL (or copy REDIS_PRIVATE_URL).
REDIS_URL="redis://localhost:6379"
CHAT_ATTACHMENT_SECRET="generate-random-secret-for-production"
PORT=3001
NODE_ENV=development
BETTER_AUTH_SECRET="change-this-to-a-random-secret-in-production"
BETTER_AUTH_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"
# Production: CORS_ORIGIN="https://tmgo.com,https://www.tmgo.com" (comma-separated)

# For seed:admin script (bun run seed:admin)
# ADMIN_EMAIL=admin@tmgo.com
# ADMIN_PASSWORD=your-secure-password
# ADMIN_NAME=Admin

# Email (Resend). Получить ключ: https://resend.com → API Keys
RESEND_API_KEY=re_...

# Хранилище файлов: local (диск) или r2 (Cloudflare R2). По умолчанию local.
# При STORAGE_DRIVER=r2 нужны R2_* (endpoint и region достраиваются автоматически).
STORAGE_DRIVER=local
# R2_ACCOUNT_ID=
# R2_BUCKET=tmgo-files
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=            # опц., дефолт https://<account_id>.r2.cloudflarestorage.com
# R2_REGION=auto          # опц., дефолт auto
