{
  "name": "@tmgo/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed:admin": "bun run scripts/seed-admin.ts",
    "migrate:profiles": "bun run scripts/migrate-profiles.ts",
    "check:expiry": "bun run scripts/document-expiry-check.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/swagger": "^1.2.0",
    "@tmgo/shared": "workspace:*",
    "better-auth": "^1.5.0",
    "drizzle-orm": "^0.45.1",
    "elysia": "latest",
    "elysia-rate-limit": "^4.5.1",
    "postgres": "^3.4.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "drizzle-kit": "^0.31.8"
  }
}
