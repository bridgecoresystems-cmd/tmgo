# Скопируй в .env.local и заполни:

# Для разработки в браузере (proxy в vite.config.ts работает сам):
# VITE_API_URL=

# Для APK (нативный Android) — IP твоего компа в локальной сети:
# VITE_API_URL=http://192.168.1.110:8000

# Для production APK — адрес VPS:
# VITE_API_URL=https://api.your-domain.com
